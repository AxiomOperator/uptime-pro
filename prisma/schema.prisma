//
// Schema derived from Knex migrations in db/knex_migrations/ and db/old_migrations/
// Do NOT use Prisma Migrate — the app uses Knex migrations exclusively.

generator client {
  provider   = "prisma-client-js"
  output     = "../server/generated/prisma"
  engineType = "binary"
}

datasource db {
  provider = "sqlite"
}

model User {
  id               Int     @id @default(autoincrement())
  username         String  @unique
  password         String?
  active           Boolean @default(true)
  timezone         String?
  twofa_secret     String?
  twofa_status     Boolean @default(false)
  twofa_last_token String?

  @@map("user")
}

