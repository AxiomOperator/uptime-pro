  lastStartDate DateTime? @map("last_start_date")

  @@map("maintenance")
}

model MaintenanceStatusPage {
  id            Int @id @default(autoincrement())
  statusPageId  Int @map("status_page_id")
  maintenanceId Int @map("maintenance_id")

  @@map("maintenance_status_page")
}

model MonitorMaintenance {
  id            Int @id @default(autoincrement())
  monitorId     Int @map("monitor_id")
  maintenanceId Int @map("maintenance_id")

  @@map("monitor_maintenance")
}

model ApiKey {
  id          Int       @id @default(autoincrement())
  key         String
  name        String
  userId      Int       @map("user_id")
  createdDate DateTime  @default(now()) @map("created_date")
  active      Boolean   @default(true)
  expires     DateTime?

  @@map("api_key")
}

model StatMinutely {
  id        Int     @id @default(autoincrement())
  monitorId Int     @map("monitor_id")
  timestamp Int
  ping      Float
  pingMin   Float   @default(0) @map("ping_min")
  pingMax   Float   @default(0) @map("ping_max")
  up        Int
  down      Int
  extras    String?

  @@unique([monitorId, timestamp])
  @@map("stat_minutely")
}

model StatHourly {
  id        Int     @id @default(autoincrement())
  monitorId Int     @map("monitor_id")
  timestamp Int
  ping      Float
  pingMin   Float   @default(0) @map("ping_min")
  pingMax   Float   @default(0) @map("ping_max")
  up        Int
  down      Int
  extras    String?

  @@unique([monitorId, timestamp])
  @@map("stat_hourly")
}

model StatDaily {
  id        Int     @id @default(autoincrement())
  monitorId Int     @map("monitor_id")
  timestamp Int
  ping      Float
  pingMin   Float   @default(0) @map("ping_min")
