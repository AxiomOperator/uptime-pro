  keyword                                  String?
  maxretries                               Int      @default(0)
  ignore_tls                               Boolean  @default(false)
  upside_down                              Boolean  @default(false)
  maxredirects                             Int      @default(10)
  accepted_statuscodes_json                String   @default("[\"200-299\"]")
  dns_resolve_type                         String?
  dns_resolve_server                       String?
  dns_last_result                          String?
  retry_interval                           Int      @default(0)
  push_token                               String?
  method                                   String   @default("GET")
